# Copy this file to .env and fill in real values before deploying to production.
# Never commit a real .env file — only .env.example should be in version control.

# ---------------------------------------------------------------------------
# Contact form backend override (see README.md -> "Contact form setup")
# Leave empty to use the default Formspree endpoint in siteConfig:
# https://formspree.io/f/mzdlrzrq
# Set only if you want staging or production to post somewhere else.
# ---------------------------------------------------------------------------
VITE_CONTACT_FORM_ENDPOINT=

# ---------------------------------------------------------------------------
# Analytics
# The default GA4 ID is also set in siteConfig.analytics.gaMeasurementId.
# Override this only for staging or a different production property.
# ---------------------------------------------------------------------------
VITE_GA_MEASUREMENT_ID=G-5MLNQBXJY3
